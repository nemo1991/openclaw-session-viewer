{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "printWidth": 100,
  "trailingComma": "es5",
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.md",
      "options": { "proseWrap": "preserve", "printWidth": 120 }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": { "tabWidth": 2, "singleQuote": false }
    }
  ]
}
