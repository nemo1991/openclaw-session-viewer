{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Session Viewer",
  "version": "0.1.0",
  "identifier": "com.openclaw.sessionviewer",
  "build": {
    "beforeDevCommand": "pnpm --filter @ocsv/frontend dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @ocsv/frontend build",
    "frontendDist": "../packages/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 会话查看器",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "OpenClaw / Claude Code 会话查看器",
    "longDescription": "跨平台桌面应用,本地浏览 OpenClaw 和 Claude Code 的会话转录。支持搜索、导出、大模型分析。",
    "publisher": "OpenClaw Viewer Contributors",
    "copyright": "MIT",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
